{
  "name": "@cmdforge/tip",
  "version": "0.0.3",
  "author": {
    "name": "Fluttershy",
    "url": "https://github.com/Fluttershy"
  },
  "type": "module",
  "description": "Tool Interface Protocol (TIP) is a small set of helpers for defining tool contracts once and then reusing them across MCP servers, MCP clients, and a desktop UI shell.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmdforge/tip.git"
  },
  "contributors": [
    {
      "name": "Fluttershy",
      "url": "https://github.com/Fluttershy"
    }
  ],
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@mcp-ui/server": "6.1.0",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}