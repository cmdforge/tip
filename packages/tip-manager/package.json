{
  "name": "@cmdforge/tip-manager",
  "version": "0.0.5",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Fluttershy",
    "url": "https://github.com/Fluttershy"
  },
  "description": "Manages TIP server listings, registrations, and process brokering.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmdforge/tip.git"
  },
  "contributors": [
    {
      "name": "Fluttershy",
      "url": "https://github.com/Fluttershy"
    }
  ],
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "bin": {
    "tip-manager": "./dist/bin/daemon.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx src/**/*.test.ts",
    "generate": "npx -y openapi-typescript https://registry.modelcontextprotocol.io/openapi.yaml --root-types --root-types-no-schema-prefix -o ./src/shared/registry/api.ts"
  },
  "dependencies": {
    "openapi-fetch": "0.17.0",
    "@cmdforge/jsonrpc": "workspace:*",
    "@cmdforge/tip": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "@types/ws": "^8.18.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
